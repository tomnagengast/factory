#!/bin/sh
set -eu

usage() {
  printf '%s\n' 'usage: bin/network-app deploy factory [args] | rollback factory [args]' >&2
  exit 2
}

[ "$#" -ge 2 ] || usage

command=$1
app=$2
[ "$app" = "factory" ] || usage

provider=${HOME:?HOME is required}/.local/bin/nags
if [ ! -x "$provider" ]; then
  printf '%s\n' "Factory deployment provider is unavailable at $provider" >&2
  exit 1
fi

shift 2
case "$command" in
  deploy)
    exec "$provider" deploy "$@"
    ;;
  rollback)
    factory_bin=$HOME/.local/share/factory/current/factory
    if [ ! -x "$factory_bin" ]; then
      factory_bin=$(command -v factory || true)
    fi
    if [ -z "$factory_bin" ] || [ ! -x "$factory_bin" ]; then
      printf '%s\n' 'Factory rollback preflight tool is unavailable' >&2
      exit 1
    fi
    data=$HOME/.local/share/factory/data
    exec "$factory_bin" state-rollback \
      --data-root "$data" \
      --provider "$provider" \
      -- "$@"
    ;;
  *)
    usage
    ;;
esac
